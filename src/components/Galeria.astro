---
import { galleryItems } from '../data/site-data';
---
<section class="galeria" id="galeria">
  <div class="container">
    <div class="section-header" style="text-align:center; margin-bottom:1.5rem;">
      <span class="section-tag dark" data-i18n="gal-tag">Momentos épicos</span>
      <h2 class="section-title dark"><span data-i18n="gal-title">Nuestra</span> <span class="g-text" data-i18n="gal-title-accent">Galería</span></h2>
    </div>
    <div class="gallery-filters" id="galleryFilters">
      <button class="gallery-filter active" data-filter="all" data-i18n="gal-filter-all">Todo</button>
      <button class="gallery-filter" data-filter="Albercas" data-i18n="gal-filter-albercas">Albercas</button>
      <button class="gallery-filter" data-filter="Comida" data-i18n="gal-filter-comida">Comida</button>
      <button class="gallery-filter" data-filter="AquaBar">AquaBar</button>
      <button class="gallery-filter" data-filter="Instalaciones" data-i18n="gal-filter-inst">Instalaciones</button>
    </div>
  </div>
  <div class="gallery-grid" id="galleryGrid">
    {galleryItems.map((item, i) => (
      <div class="gallery-item" data-delay={i * 0.08} data-filter-category={item.filter} style={`grid-row: span ${Math.ceil(item.h / 10)};`}>
        <div class="gallery-item-inner" style={`background: ${item.color}; min-height:${item.h}px;`}>
          <img src={item.img} alt={item.title} loading="lazy" />
        </div>
        <div class="gallery-item-overlay">
          <h4>{item.title}</h4>
          <p>{item.filter}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<div class="lightbox" id="lightbox">
  <div class="lightbox-close" id="lightboxClose">✕</div>
  <div class="lightbox-content" id="lightboxContent"></div>
</div>
