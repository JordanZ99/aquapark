---
import { stats } from '../data/site-data';
---
<section class="numeros" id="numeros">
  <div class="wave-top">
    <svg viewBox="0 0 2400 60" preserveAspectRatio="none" style="height:60px;">
      <path d="M0,30 C400,60 800,0 1200,30 C1600,60 2000,0 2400,30 L2400,60 L0,60Z" fill="var(--color-primary)" opacity="0.6"/>
      <path d="M0,40 C300,10 600,50 1200,40 C1800,30 2100,50 2400,40 L2400,60 L0,60Z" fill="var(--color-primary)" opacity="0.8"/>
    </svg>
  </div>
  <div class="container">
    <div class="section-header" style="text-align:center; margin-bottom:3rem;">
      <span class="section-tag dark">Números que hablan</span>
      <h2 class="section-title dark">Nuestra <span class="g-text">Experiencia</span></h2>
    </div>
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class="stat-card" data-delay={i * 0.15}>
          <div class="stat-icon">
            {s.icon === 'visitors' && <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
            {s.icon === 'pools' && <svg viewBox="0 0 24 24"><path d="M2 12c1.5-3 3.5-3 5 0s3.5 3 5 0 3.5-3 5 0 3.5 3 5 0"/><path d="M2 17c1.5-3 3.5-3 5 0s3.5 3 5 0 3.5-3 5 0 3.5 3 5 0"/><line x1="2" y1="22" x2="22" y2="22"/></svg>}
            {s.icon === 'slides' && <svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>}
            {s.icon === 'years' && <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>}
          </div>
          <div class="stat-number" data-target={s.value} data-suffix={s.suffix}>0</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
  <div class="wave-bottom">
    <svg viewBox="0 0 2400 60" preserveAspectRatio="none" style="height:60px;">
      <path d="M0,30 C400,60 800,0 1200,30 C1600,60 2000,0 2400,30 L2400,60 L0,60Z" fill="var(--color-primary)" opacity="0.6"/>
    </svg>
  </div>
</section>
